{
  "name": "nest-graphql-prisma",
  "version": "1.0.0",
  "description": "NestJS project with Apollo Server and Prisma",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test:env": "npx dotenv-cli -e .env.test -o -- node -e",
    "test": "npx dotenv-cli -e .env.test -o -- jest",
    "test:watch": "npx dotenv-cli -e .env.test -o -- jest --watch",
    "test:cov": "npx dotenv-cli -e .env.test -o -- jest --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@apollo/server": "^5.0.3",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/common": "^11.0.6",
    "@nestjs/core": "^11.0.6",
    "@nestjs/graphql": "^13.0.1",
    "@nestjs/platform-express": "^11.0.6",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.94.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "graphql": "^16.9.0",
    "graphql-ws": "^5.16.0",
    "jwks-rsa": "^3.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nestjs/cli": "^11.0.12",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "prettier": "3.6.2",
    "prettier-plugin-prisma": "5.0.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.47.0"
  },
  "overrides": {
    "@apollo/server": "^5.0.3"
  }
}
