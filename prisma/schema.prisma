// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ACADEMY & USER MODULE
// ============================================================================

enum AcademyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  ADMIN    // Super admin
  OWNER    // Dueño de academia
  STAFF    // Personal administrativo
  TEACHER  // Profesor
  STUDENT  // Estudiante que puede loguearse
}

model Academy {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  status      AcademyStatus @default(ACTIVE)
  
  country     String        // "AR", "MX"
  currency    String        // "ARS", "USD"
  timezone    String        // "America/Argentina/Buenos_Aires"
  
  email       String?
  phone       String?
  address     String?
  
  ownerUserId String
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  users           User[]
  students        Student[]
  teachers        Teacher[]
  programs        Program[]
  classes         Class[]
  fees            Fee[]
  invoices        Invoice[]
  features        AcademyFeature[]
  afipSettings    AcademyAfipSettings?
  billingProfiles BillingProfile[]
  bulkOperations  BulkOperation[]
  families        Family[]
  familyGuardians FamilyGuardian[]
}

model User {
  id              String    @id @default(uuid())
  supabaseUserId  String    @unique  // auth.users.id de Supabase
  
  academyId       String
  academy         Academy   @relation(fields: [academyId], references: [id])
  
  role            UserRole
  
  firstName       String
  lastName        String
  email           String
  phone           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relación opcional con Student (si el user es un estudiante)
  student         Student?
  
  @@index([supabaseUserId])
  @@index([academyId])
}

// ============================================================================
// COMMON ENUMS
// ============================================================================

enum Status {
  ENABLED
  DISABLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_SPECIFIED
}

enum DocumentType {
  DNI
  PASSPORT
  NIE
  OTHER
}

enum GuardianRelationship {
  PADRE
  MADRE
  ABUELO
  ABUELA
  TIO
  TIA
  TUTOR
  OTRO
}

enum Language {
  ENGLISH
  SPANISH
  FRENCH
  ITALIAN
  PORTUGUESE
}

// ============================================================================
// STUDENTS MODULE
// ============================================================================

model Student {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String   @unique
  phoneNumber String?
  status      Status   @default(ENABLED)

  academyId   String
  academy     Academy       @relation(fields: [academyId], references: [id])

  // Link opcional a User (cuando el estudiante puede loguearse)
  userId      String?       @unique
  user        User?         @relation(fields: [userId], references: [id])

  // Link a Family (cada estudiante pertenece a máximo una familia)
  familyId    String?
  family      Family?       @relation(fields: [familyId], references: [id])

  // Información personal
  birthDate        DateTime?
  gender           Gender?
  documentType     DocumentType?
  documentNumber   String?

  // Información de contacto
  phoneCountryCode String?
  address          String?
  city             String?
  state            String?
  country          String?
  postalCode       String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  charges         Charge[]
  invoices        Invoice[]
  credits         StudentCredit[]
  billingProfiles BillingProfile[]
  classStudents   ClassStudent[]

  @@index([academyId])
  @@index([familyId])
}

// ============================================================================
// TEACHERS MODULE
// ============================================================================

model Teacher {
  id             String       @id @default(uuid())
  firstName      String
  lastName       String
  birthDate      DateTime?
  gender         Gender?
  documentType   DocumentType?
  documentNumber String?
  avatarUrl      String?
  status         Status       @default(ENABLED)

  academyId      String
  academy        Academy                @relation(fields: [academyId], references: [id])

  contactInfo    ContactInfo?
  classes        Class[]

  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([academyId])
}

model ContactInfo {
  id               String   @id @default(uuid())

  teacherId        String?  @unique
  teacher          Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  email            String?
  phoneCountryCode String?
  phoneNumber      String?

  address          String?
  country          String?
  state            String?
  city             String?
  postalCode       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([teacherId])
}

// ============================================================================
// FAMILIES MODULE
// ============================================================================

model Family {
  id        String   @id @default(uuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])

  name      String
  tags      String[]
  status    Status   @default(ENABLED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardians FamilyGuardian[]
  students  Student[]

  @@index([academyId])
  // NOTA: Agregar GIN index manualmente en migration SQL:
  // CREATE INDEX "Family_tags_idx" ON "Family" USING GIN ("tags");
}

model FamilyGuardian {
  id               String               @id @default(uuid())
  academyId        String
  academy          Academy              @relation(fields: [academyId], references: [id])

  familyId         String
  family           Family               @relation(fields: [familyId], references: [id], onDelete: Cascade)

  // Información personal
  firstName        String
  lastName         String
  relationship     GuardianRelationship
  birthDate        DateTime?
  gender           Gender?
  documentType     DocumentType?
  documentNumber   String?

  // Información de contacto (embebida flat)
  email            String?
  phoneCountryCode String?
  phoneNumber      String?
  address          String?
  city             String?
  state            String?
  country          String?
  postalCode       String?

  // Preferencias
  emailNotifications Boolean @default(true)
  status             Status  @default(ENABLED)
  avatarUrl          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyId])
  @@index([academyId])
}

// ============================================================================
// PROGRAMS & CLASSES MODULE
// ============================================================================

model Program {
  id          String   @id @default(uuid())
  name        String
  language    Language
  description String?
  status      Status   @default(ENABLED)

  academyId   String
  academy     Academy  @relation(fields: [academyId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classes     Class[]

  @@index([academyId])
}

model Class {
  id        String   @id @default(uuid())
  name      String
  programId String
  program   Program  @relation(fields: [programId], references: [id])
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  startDate DateTime
  endDate   DateTime
  capacity  Int?
  code      String?
  description String?

  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])

  students  ClassStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId])
  @@index([programId])
  @@index([teacherId])
}

model ClassStudent {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

// ============================================================================
// FEES MODULE
// ============================================================================

enum FeeType {
  ONE_OFF
  MONTHLY
  PERIODIC
}

enum FeePeriod {
  EVERY_WEEK
  TWICE_A_MONTH
  EVERY_MONTH
  EVERY_2_MONTHS
  EVERY_3_MONTHS
  EVERY_4_MONTHS
  EVERY_5_MONTHS
  EVERY_6_MONTHS
}

model Fee {
  id          String     @id @default(uuid())
  description String
  type        FeeType
  startDate   DateTime   // desde qué mes empieza el schedule del fee
  cost        Int
  occurrences Int?
  period      FeePeriod?
  
  academyId   String
  academy     Academy    @relation(fields: [academyId], references: [id])
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  charges     Charge[]
  
  @@index([academyId])
}

// ============================================================================
// CHARGES MODULE
// ============================================================================

enum ChargeStatus {
  PENDING
  PAID
  CANCELLED
  INVOICED
}

model Charge {
  id                String        @id @default(uuid())
  fee               Fee           @relation(fields: [feeId], references: [id])
  feeId             String
  student           Student       @relation(fields: [studentId], references: [id])
  studentId         String
  amount            Int           // Monto en centavos (snapshot de Fee.cost)
  periodMonth       String        // "2026-01" - mes al que pertenece (para agrupar/invoices)
  installmentNumber Int           // 1, 2, 3... N - número de cuota global
  issueDate         DateTime      // Fecha de emisión (día de cobro)
  dueDate           DateTime      // Fecha de vencimiento (issueDate + graceDays)
  status            ChargeStatus  @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  invoiceLines      InvoiceLine[]

  @@unique([studentId, feeId, installmentNumber])
  @@index([studentId])
  @@index([feeId])
  @@index([periodMonth])
}

// ============================================================================
// INVOICE MODULE
// ============================================================================

enum InvoiceStatus {
  ISSUED
  PAID
  PARTIALLY_PAID
  VOID
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum InvoiceLineType {
  CHARGE // Viene de un Charge existente
  MANUAL // Fee ad-hoc (materiales, ajuste, clase extra)
}

model Invoice {
  id               String        @id @default(uuid())
  invoiceNumber    Int           @default(autoincrement())

  // Recipient (studentId nullable para "OTHER")
  studentId        String?
  student          Student?      @relation(fields: [studentId], references: [id])
  recipientName    String        // Siempre requerido (snapshot o manual)
  recipientEmail   String?
  recipientPhone   String?
  recipientAddress String?

  // Billing profile (datos fiscales del receptor)
  billingProfileId String?
  billingProfile   BillingProfile? @relation(fields: [billingProfileId], references: [id])

  // Multi-tenancy
  academyId        String
  academy          Academy       @relation(fields: [academyId], references: [id])

  issueDate        DateTime
  dueDate          DateTime
  publicNotes      String?
  privateNotes     String?
  status           InvoiceStatus @default(ISSUED)

  // Totales (cache - SIEMPRE calculados en backend)
  subtotal         Int           // Suma de originalAmount de lines activas
  totalDiscount    Int           // Suma de descuentos de lines activas
  total            Int           // Suma de finalAmount de lines activas

  // Campos de pagos (cache - calculados automáticamente)
  paidAmount       Int           @default(0) // sum(PAYMENT approved) - sum(REFUND approved)
  balance          Int           @default(0) // total - paidAmount

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lines            InvoiceLine[]
  payments         Payment[]
  generatedCredits StudentCredit[]

  // Fiscal layer (AFIP)
  afip             AfipInvoice?

  @@index([studentId])
  @@index([academyId])
  @@index([status])
}

model InvoiceLine {
  id             String          @id @default(uuid())
  invoiceId      String
  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Tipo de linea
  type           InvoiceLineType @default(CHARGE)

  // Charge (nullable - null si es MANUAL)
  chargeId       String?
  charge         Charge?         @relation(fields: [chargeId], references: [id])

  // Datos de la linea
  description    String          // Snapshot de Fee.description o manual
  originalAmount Int             // Snapshot de Charge.amount o manual

  // Descuento
  discountType   DiscountType?
  discountValue  Int?            // Porcentaje (0-100) o monto fijo en centavos
  discountReason String?
  finalAmount    Int             // originalAmount - descuento calculado

  // Flag tecnico para unicidad vs historico
  isActive       Boolean         @default(true)

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([invoiceId])
  @@index([chargeId])
  // NOTA: El unique parcial se crea en la migracion SQL manualmente:
  // CREATE UNIQUE INDEX uniq_active_charge_invoiceline
  // ON "InvoiceLine" ("chargeId")
  // WHERE "chargeId" IS NOT NULL AND "isActive" = true;
}

// ============================================================================
// PAYMENTS MODULE
// ============================================================================

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
}

enum PaymentStatus {
  PENDING_REVIEW // Comprobante subido, esperando aprobación (futuro)
  APPROVED       // Pago confirmado
  REJECTED       // Rechazado (queda registrado)
  VOID           // Anulado (soft delete)
}

enum PaymentType {
  PAYMENT // Plata que entra (pago del alumno)
  REFUND  // Plata que sale (devolución)
}

model Payment {
  id         String        @id @default(uuid())
  invoiceId  String
  invoice    Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  type       PaymentType   @default(PAYMENT)
  amount     Int           // centavos (siempre positivo)
  method     PaymentMethod
  status     PaymentStatus @default(APPROVED)
  
  paidAt     DateTime      // fecha real del pago
  reference  String?       // nro transferencia, últimos 4 dígitos
  
  // Auditoría anulación/rechazo
  voidReason String?
  voidedAt   DateTime?
  
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  
  generatedCredit StudentCredit? // Crédito que generó este pago (si hubo overpay)
  
  @@index([invoiceId])
  @@index([paidAt])
  @@index([status])
}

// ============================================================================
// CREDITS MODULE
// ============================================================================

enum CreditStatus {
  AVAILABLE // Crédito disponible para usar
  USED      // Crédito consumido (total o parcialmente)
  VOID      // Anulado (si se anuló el payment origen)
}

model StudentCredit {
  id              String       @id @default(uuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id])
  
  amount          Int          // Monto original del crédito (centavos)
  availableAmount Int          // Monto disponible (para uso parcial futuro)
  status          CreditStatus @default(AVAILABLE)
  
  // Trazabilidad: de dónde vino el crédito
  sourcePaymentId String       @unique
  sourcePayment   Payment      @relation(fields: [sourcePaymentId], references: [id])
  sourceInvoiceId String
  sourceInvoice   Invoice      @relation(fields: [sourceInvoiceId], references: [id])
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([studentId])
  @@index([status])
  @@index([sourcePaymentId])
}

// ============================================================================
// FEATURE FLAGS MODULE
// ============================================================================

model AcademyFeature {
  id        String   @id @default(uuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])

  key       String   // "AFIP", "PAYMENTS", "WHATSAPP", ...
  enabled   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academyId, key])
  @@index([academyId])
  @@index([key])
}

// ============================================================================
// AFIP MODULE
// ============================================================================

enum AcademyTaxStatus {
  MONOTRIBUTO
  RESPONSABLE_INSCRIPTO
  EXENTO
  CONSUMIDOR_FINAL
}

enum AfipEnvironment {
  HOMO
  PROD
}

enum AfipDelegationStatus {
  PENDING // Nunca verificada
  OK      // Delegación válida
  ERROR   // Delegación rota / revocada
}

enum AfipOnboardingStep {
  FISCAL_DATA   // Step 1 completado (datos fiscales guardados)
  DELEGATION_1  // Step 2 (pendiente de delegar en ARCA)
  DELEGATION_2  // Step 3 (pendiente de verificar la delegación)
  COMPLETED     // Onboarding finalizado
}

model AcademyAfipSettings {
  id               String               @id @default(uuid())
  academyId        String               @unique
  academy          Academy              @relation(fields: [academyId], references: [id])

  taxStatus        AcademyTaxStatus
  cuit             String

  // Datos del padrón ARCA (guardados al confirmar Step 1)
  razonSocial        String?
  personeria         String?              // "Física" / "Jurídica"
  condicionIva       String?
  domicilioFiscal    String?
  actividadPrincipal String?

  defaultPtoVta    Int                  @default(1)
  environment      AfipEnvironment      @default(HOMO)

  // Solo relevante para Responsable Inscripto; Monotributo no aplica IVA
  vatRatePermil    Int?                 // 21000 = 21.000%

  delegationStatus AfipDelegationStatus @default(PENDING)
  delegatedAt      DateTime?

  onboardingStep   AfipOnboardingStep   @default(FISCAL_DATA)

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  salesPoints      AfipSalesPoint[]
}

model AfipSalesPoint {
  id               String              @id @default(uuid())
  afipSettingsId   String
  afipSettings     AcademyAfipSettings @relation(fields: [afipSettingsId], references: [id])

  number           Int                 // Numero de punto de venta en ARCA
  name             String              // Nombre descriptivo (ej: "Sede Central")
  isActive         Boolean             @default(true)
  isEnabledForArca Boolean             @default(false) // Se setea true via mutation de validacion

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([afipSettingsId, number])
  @@index([afipSettingsId])
}

// ============================================================================
// BILLING PROFILE (datos fiscales del receptor)
// ============================================================================

enum BillingDocType {
  CONSUMIDOR_FINAL // AFIP DocTipo 99 / DocNro 0
  DNI
  CUIT
}

enum BillingTaxCondition {
  CONSUMIDOR_FINAL
  MONOTRIBUTO
  RESPONSABLE_INSCRIPTO
  EXENTO
}

model BillingProfile {
  id           String              @id @default(uuid())
  academyId    String
  academy      Academy             @relation(fields: [academyId], references: [id])

  // Dueño (hoy Student; mañana puede ser Parent/Guardian)
  studentId    String?
  student      Student?            @relation(fields: [studentId], references: [id])

  displayName  String
  docType      BillingDocType
  docNumber    String?             // null si CONSUMIDOR_FINAL
  taxCondition BillingTaxCondition

  razonSocial  String?
  personeria   String?             // "Física" / "Jurídica"

  email        String?
  phone        String?
  address      String?             // Resumen del domicilio fiscal

  // Domicilio fiscal desglosado
  street       String?             // Calle + número
  apartment    String?             // Departamento / Piso
  zipCode      String?             // Código postal
  province     String?             // Provincia
  city         String?             // Ciudad / Localidad

  isDefault    Boolean             @default(false)

  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  invoices     Invoice[]

  @@index([academyId])
  @@index([studentId])
}

// ============================================================================
// AFIP FISCALIZATION (1:1 con Invoice)
// ============================================================================

enum AfipFiscalStatus {
  EMITTING // Intento de fiscalización en curso
  EMITTED  // Fiscalizada exitosamente (CAE + cbteNro)
  ERROR    // Error en la fiscalización
}

model AfipInvoice {
  id            String           @id @default(uuid())

  invoiceId     String           @unique
  invoice       Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  status        AfipFiscalStatus @default(EMITTING)

  // Snapshot de datos fiscales del receptor usados para la emisión
  recipientName String
  docType       BillingDocType
  docNumber     String?
  taxCondition  BillingTaxCondition

  // Parámetros AFIP usados
  ptoVta        Int
  cbteTipo      Int              // 6=B, 11=C (MVP)
  concepto      Int              // 2=Servicios (MVP)
  cbteFch       DateTime         // Fecha de emisión (normalmente "hoy")

  // Resultado AFIP (solo cuando EMITTED)
  cbteNro       Int?
  cae           String?
  caeVto        DateTime?

  // Debug/soporte
  lastError     String?
  requestJson   Json?            // Guardar solo en ERROR si se prefiere
  responseJson  Json?            // Guardar solo en ERROR si se prefiere

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// ============================================================================
// BULK OPERATIONS MODULE
// ============================================================================

enum BulkOperationType {
  BULK_INVOICE
  BULK_AFIP
}

enum BulkOperationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model BulkOperation {
  id             String              @id @default(uuid())
  type           BulkOperationType
  status         BulkOperationStatus @default(PENDING)

  academyId      String
  academy        Academy             @relation(fields: [academyId], references: [id])

  totalItems     Int
  completedItems Int                 @default(0)
  failedItems    Int                 @default(0)
  skippedItems   Int                 @default(0)

  results        Json                @default("[]")
  params         Json

  triggerRunId   String?

  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([academyId])
  @@index([status])
}
