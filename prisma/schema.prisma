// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StudentStatus {
  ENABLED
  DISABLED
}

model Student {
  id          String        @id @default(uuid())
  firstName   String
  lastName    String
  email       String        @unique
  phoneNumber String?
  status      StudentStatus @default(ENABLED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  charges     Charge[]
}

enum FeeType {
  ONE_OFF
  MONTHLY
  PERIODIC
}

enum FeePeriod {
  EVERY_WEEK
  TWICE_A_MONTH
  EVERY_MONTH
  EVERY_2_MONTHS
  EVERY_3_MONTHS
  EVERY_4_MONTHS
  EVERY_5_MONTHS
  EVERY_6_MONTHS
}

model Fee {
  id          String     @id @default(uuid())
  description String
  type        FeeType
  startDate   DateTime   // desde qué mes empieza el schedule del fee
  cost        Int
  occurrences Int?
  period      FeePeriod?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  charges     Charge[]
}

enum ChargeStatus {
  PENDING
  PAID
  CANCELLED
  INVOICED
}

model Charge {
  id                String       @id @default(uuid())
  fee               Fee          @relation(fields: [feeId], references: [id])
  feeId             String
  student           Student      @relation(fields: [studentId], references: [id])
  studentId         String
  amount            Int          // Monto en centavos (snapshot de Fee.cost)
  periodMonth       String       // "2026-01" - mes al que pertenece (para agrupar/invoices)
  installmentNumber Int          // 1, 2, 3... N - número de cuota global
  issueDate         DateTime     // Fecha de emisión (día de cobro)
  dueDate           DateTime     // Fecha de vencimiento (issueDate + graceDays)
  status            ChargeStatus @default(PENDING)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([studentId, feeId, installmentNumber])
  @@index([studentId])
  @@index([feeId])
  @@index([periodMonth])
}
